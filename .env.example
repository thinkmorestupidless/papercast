# Copy to .env and fill in your values before running scripts/setup-akka-secrets.sh

# Required
OPENAI_API_KEY=your-openai-api-key

# Optional — leave blank to disable audio generation
ELEVENLABS_API_KEY=

# Optional — higher PubMed rate limits
NCBI_API_KEY=

# Optional — higher Semantic Scholar rate limits
S2_API_KEY=
